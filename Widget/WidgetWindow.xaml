<Window x:Class="Window_Alert_App.Widget.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="310"
        SizeToContent="Height"
        Topmost="False">

    <Border x:Name="MainBorder"
            CornerRadius="12"
            Background="{DynamicResource WidgetBgBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                              Color="#80000000" Opacity="0.5"/>
        </Border.Effect>
        <Grid x:Name="ContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 콘텐츠 영역 (CompactView / NormalView 교체) -->
            <Viewbox x:Name="ContentViewbox" Grid.Row="0" Margin="0,4" Stretch="None">
                <ContentPresenter x:Name="ContentArea"/>
            </Viewbox>

        </Grid>
    </Border>
</Window>
