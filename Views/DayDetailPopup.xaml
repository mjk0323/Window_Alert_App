<Window x:Class="Window_Alert_App.Views.DayDetailPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="300"
        Topmost="True">

    <Border CornerRadius="10"
            Background="{DynamicResource WidgetBgBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Color="#AA000000" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- 헤더 (드래그 가능) -->
            <Grid Grid.Row="0" Margin="12,0,8,0"
                  MouseLeftButtonDown="Header_DragMove" Cursor="SizeAll">
                <TextBlock x:Name="DateHeader"
                           VerticalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseBtn_Click"
                        FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                        Cursor="Arrow"/>
            </Grid>

            <!-- 일정 목록 -->
            <ScrollViewer Grid.Row="1"
                          MaxHeight="240"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,4">
                <StackPanel x:Name="EventListPanel" Margin="8,0"/>
            </ScrollViewer>

            <!-- 구분선 -->
            <Border Grid.Row="2" Background="{DynamicResource WidgetBorderBrush}" Margin="8,0"/>

            <!-- 일정 추가 버튼 -->
            <Button Grid.Row="3" Content="+ 일정 추가"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource ModeButtonStyle}"
                    Foreground="{DynamicResource AccentBrush}"
                    FontSize="12"
                    Click="AddEvent_Click"/>
        </Grid>
    </Border>
</Window>
