<UserControl x:Class="Window_Alert_App.Views.CompactView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="290">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 날짜 내비 + 모드 전환 (드래그 가능) -->
        <Grid Grid.Row="0" Margin="8,0"
              MouseLeftButtonDown="Header_DragMove" Cursor="SizeAll">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 날짜 이동 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="◀" Style="{StaticResource NavArrowStyle}"
                        Command="{Binding PreviousDayCommand}" Padding="6,2" Cursor="Arrow"/>
                <TextBlock x:Name="DateText" VerticalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="4,0"/>
                <Button Content="▶" Style="{StaticResource NavArrowStyle}"
                        Command="{Binding NextDayCommand}" Padding="6,2" Cursor="Arrow"/>
            </StackPanel>

            <!-- 모드 전환 버튼 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="N" Style="{StaticResource ModeButtonStyle}"
                        Command="{Binding SwitchModeCommand}" CommandParameter="Normal"
                        Margin="0,0,2,0" Cursor="Arrow"/>
                <Button Content="W" Style="{StaticResource ModeButtonStyle}"
                        Command="{Binding SwitchModeCommand}" CommandParameter="Wide"
                        Cursor="Arrow"/>
            </StackPanel>
        </Grid>

        <!-- 일정 목록 + 추가 버튼 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                <StackPanel>
                    <!-- 일정 없을 때 -->
                    <TextBlock Text="일정이 없습니다"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDayEvents.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding SelectedDayEvents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,3,8,3" Cursor="Hand"
                                      MouseLeftButtonDown="EventRow_MouseLeftButtonDown">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 완료 체크박스 -->
                                    <CheckBox Grid.Column="0"
                                              Style="{StaticResource EventCheckBoxStyle}"
                                              IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                              VerticalAlignment="Center"/>

                                    <!-- 시간 -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StartTime, StringFormat=HH:mm}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentLightBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- 제목 (완료 시 취소선) -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Title}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 긴급 표시 -->
                                    <Ellipse Grid.Column="3"
                                             Width="6" Height="6"
                                             Fill="{DynamicResource UrgentBrush}"
                                             Margin="4,0,0,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUrgent}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- 구분선 -->
            <Border Grid.Row="1" Background="{DynamicResource WidgetBorderBrush}" Margin="8,0"/>

            <!-- 일정 추가 버튼 -->
            <Button Grid.Row="2" Content="+ 일정 추가"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Style="{StaticResource ModeButtonStyle}"
                    Foreground="{DynamicResource AccentBrush}" FontSize="12"
                    Click="AddEvent_Click"/>
        </Grid>
    </Grid>
</UserControl>
