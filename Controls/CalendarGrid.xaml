<UserControl x:Class="Window_Alert_App.Controls.CalendarGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 월 헤더 -->
        <Grid Grid.Row="0" Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀" Style="{StaticResource NavArrowStyle}"
                    Click="PrevMonth_Click"/>
            <TextBlock Grid.Column="1" x:Name="MonthHeader"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Cursor="SizeAll"
                       MouseLeftButtonDown="MonthHeader_DragMove"/>
            <Button Grid.Column="2" Content="▶" Style="{StaticResource NavArrowStyle}"
                    Click="NextMonth_Click" Margin="0,0,58,0"/>
        </Grid>

        <!-- 요일 헤더 -->
        <Grid Grid.Row="1" Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="일" FontSize="10" Foreground="{DynamicResource UrgentBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="월" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="화" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="수" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="목" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="금" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="6" Text="토" FontSize="10" Foreground="{DynamicResource AccentLightBrush}" HorizontalAlignment="Center"/>
        </Grid>

        <!-- 날짜 그리드 -->
        <UniformGrid x:Name="DaysGrid" Grid.Row="2" Rows="6" Columns="7" Margin="4,2,4,4"/>
    </Grid>
</UserControl>
