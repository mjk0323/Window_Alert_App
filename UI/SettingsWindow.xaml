<Window x:Class="Window_Alert_App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="400" SizeToContent="Height"
        MaxHeight="640"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource WidgetBgBrush}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WidgetBorderBrush}"/>
            <Setter Property="Margin" Value="0,16,0,16"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource HoverBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,20,20,0">

            <!-- ── 일반 ── -->
            <TextBlock Text="일반" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="StartupCheck"
                      Content="Windows 시작 시 자동 실행"
                      Style="{StaticResource SettingCheckBox}"/>

            <Border Style="{StaticResource SectionDivider}"/>

            <!-- ── 위젯 ── -->
            <TextBlock Text="위젯" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="WidgetEnabledCheck"
                      Content="위젯 사용 (해제 시 트레이 아이콘 + 알림만)"
                      Style="{StaticResource SettingCheckBox}"/>

            <StackPanel Margin="0,12,0,0">
                <TextBlock Text="기본 모드" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="CompactRadio" Content="Compact"
                                 Style="{StaticResource SettingRadio}"
                                 GroupName="WidgetMode"/>
                    <RadioButton x:Name="NormalRadio" Content="Normal"
                                 Style="{StaticResource SettingRadio}"
                                 GroupName="WidgetMode"/>
                    <RadioButton x:Name="WideRadio" Content="Wide"
                                 Style="{StaticResource SettingRadio}"
                                 GroupName="WidgetMode"/>
                </StackPanel>
            </StackPanel>

            <!-- 테마 색상 -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="테마 색상" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"/>
                <WrapPanel x:Name="ThemePanel" Orientation="Horizontal">
                    <!-- 스와치는 코드에서 생성 -->
                </WrapPanel>
            </StackPanel>

            <Border Style="{StaticResource SectionDivider}"/>

            <!-- ── 계정 ── -->
            <TextBlock Text="계정" Style="{StaticResource SectionHeader}"/>
            <Border Background="{DynamicResource HoverBgBrush}" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock x:Name="AuthStatusText"
                               Text="연결된 계정 없음"
                               FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ConnectBtn" Content="계정 연결"
                                Style="{StaticResource SaveBtn}"
                                Click="ConnectBtn_Click" Margin="0,0,8,0"/>
                        <Button x:Name="DisconnectBtn" Content="연결 해제"
                                Style="{StaticResource CancelBtn}"
                                Click="DisconnectBtn_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 하단 버튼 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,20">
                <Button Content="취소" Style="{StaticResource CancelBtn}"
                        Click="CancelBtn_Click" Margin="0,0,8,0"/>
                <Button Content="저장" Style="{StaticResource SaveBtn}"
                        Click="SaveBtn_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
